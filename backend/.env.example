# Tavily settings used by backend/src/services/macroThemeService.ts
# Keep your real .env file out of git (see root .gitignore).

# Base URL for the Tavily API (example: https://api.tavily.com)
TRAVILY_BASE_URL=https://api.tavily.com

# Your API key.
TRAVILY_API_KEY=

# Network timeout (ms) for the trends request.
TRAVILY_TIMEOUT_MS=8000

# Macro query used for dynamic theme generation.
TRAVILY_MACRO_QUERY=India macro trends sectors growth 2026 infrastructure demand sectoral themes India

# Restrict sources (comma separated)
TRAVILY_INCLUDE_DOMAINS=moneycontrol.com,economictimes.indiatimes.com,business-standard.com,screener.in

# Theme cache TTL (1-2 hours recommended).
THEMES_CACHE_TTL_MS=7200000

# OpenAI (AI is used only for keyword extraction, optional tag enrichment, and optional top-3 reason polish)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_BASE_URL=https://api.openai.com/v1

# Backend port
PORT=3000

